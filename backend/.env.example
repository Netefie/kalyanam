# ---- Server ----
NODE_ENV=development
PORT=5000

# Comma-separated list of allowed frontend origins (no trailing slash).
# Next uses :3001 when :3000 is taken, so both are allowed by default.
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ---- Database ----
# Local dev:   mongodb://127.0.0.1:27017/kalyanam
# Atlas (free M0): mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/kalyanam?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/kalyanam

# ---- Auth ----
# Generate a strong secret, e.g. `openssl rand -base64 32`
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- Email (SMTP) ----
# Leave blank to disable email — bookings still work, sending is just skipped.
# Gmail example: host=smtp.gmail.com, port=465, secure=true, user=<address>,
# pass=<16-char app password>. Fill these in later.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Kalyanam Hotel & Resort <no-reply@kalyanam.com>

# ---- Seed admin (used only by `npm run seed`) ----
SEED_ADMIN_NAME=Kalyanam Admin
SEED_ADMIN_EMAIL=admin@kalyanam.com
SEED_ADMIN_PASSWORD=Kalyanam@346
