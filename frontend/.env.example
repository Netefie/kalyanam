# Base URL of the Kalyanam backend API (no trailing slash, no /api suffix).
# Copy this file to `.env.local` and adjust as needed.
#
# NOTE: macOS uses port 5000 for AirPlay Receiver. If the backend can't bind
# to 5000 locally, run it on another port (e.g. 5055) and match it here.
NEXT_PUBLIC_API_URL=http://localhost:5000
